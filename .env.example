# Copy to .env and fill in. Used by docker-compose.yml (the api runner).
#
# Gateway creds — the miner sends `Authorization: Bearer <token>` to BASE_URL over HTTP.
# Easiest source: a ccs profile. Run `ccs env <profile>` and copy the two values.
ANTHROPIC_BASE_URL=https://your-gateway.example
ANTHROPIC_AUTH_TOKEN=replace-me

# Path on the HOST to the Cowork sessions dir (bind-mounted read-only into the container).
# Windows (Docker Desktop) example — point at the real folder, forward slashes:
#   C:/Users/<you>/AppData/Local/Packages/Claude_<hash>/LocalCache/Roaming/Claude/local-agent-mode-sessions
COWORK_LOGS=./logs

# Which corpus the launcher/headless run defaults to: cowork | claude-code
MINER_SOURCE=cowork

# Optional — cap LLM spend in USD (blank = uncapped).
MINER_MAX_COST=
